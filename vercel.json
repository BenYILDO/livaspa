{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|webp|avif|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/hizmetler",
      "destination": "/hizmetler.html"
    },
    {
      "source": "/hakkimizda",
      "destination": "/hakkimizda.html"
    },
    {
      "source": "/deneyim",
      "destination": "/deneyim.html"
    },
    {
      "source": "/sss-iletisim",
      "destination": "/sss-iletisim.html"
    },
    {
      "source": "/gizlilik",
      "destination": "/gizlilik.html"
    },
    {
      "source": "/kullanim-kosullari",
      "destination": "/kullanim-kosullari.html"
    },
    {
      "source": "/kvkk",
      "destination": "/kvkk.html"
    }
  ]
}
